# Command Shortcuts

alias n="nano"
alias la="ls -la"
alias l="ls"
alias curls="curl -Iso /dev/null -w \"%{http_code}\n\""

# Git Shortcuts

alias gp="git push"
alias gb="git branch"
alias gm="git merge"
alias gs="git status"
alias gd="git diff"
alias gl="git lola"
alias glt="git lolt"
alias gln="git lolan"
alias gla="git lolaa"
alias gco="git checkout"
alias gfpa="git fetch --prune --all"
